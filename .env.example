# =============================================================================
# Lucent Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment.
# NEVER commit .env to version control — it contains secrets.
#
# For production: all *_PASSWORD and *_KEY values MUST be set to strong randoms.
# Generate with: openssl rand -base64 32
# =============================================================================

# PostgreSQL Configuration
POSTGRES_USER=lucent
POSTGRES_PASSWORD=change-me-use-openssl-rand
POSTGRES_DB=lucent

# Daemon DB role password (separate least-privilege role)
DAEMON_DB_PASSWORD=change-me-use-openssl-rand

# Database URL (for running outside Docker Compose)
# DATABASE_URL=postgresql://lucent:YOUR_PASSWORD@localhost:5433/lucent

# Server Configuration
LUCENT_HOST=0.0.0.0
LUCENT_PORT=8766

# Deployment Mode (personal or team)
# Team mode requires a license key
LUCENT_MODE=personal
# LUCENT_LICENSE_KEY=your-license-key

# Authentication Provider (basic or api_key)
LUCENT_AUTH_PROVIDER=basic

# Session TTL in hours (default: 72)
LUCENT_SESSION_TTL_HOURS=24

# Log format: human or json (default: human)
LUCENT_LOG_FORMAT=human
# LUCENT_LOG_LEVEL=INFO

# Database port (for docker-compose, default: 5433)
# LUCENT_DB_PORT=5433

# Rate limiting (requests per minute per API key, default: 100)
# LUCENT_RATE_LIMIT_PER_MINUTE=100

# Cookie security (defaults to true; set to false ONLY for local HTTP development)
# LUCENT_SECURE_COOKIES=true

# HMAC signing secret for impersonation cookies.
# MUST be set to a stable value for cookie persistence across restarts.
# Generate with: openssl rand -base64 32
# LUCENT_SIGNING_SECRET=

# CORS origins (comma-separated, restrict in production)
# LUCENT_CORS_ORIGINS=https://your-domain.com

# Secret Storage Provider (builtin, vault, aws, or azure)
LUCENT_SECRET_PROVIDER=builtin
LUCENT_SECRET_KEY=change-me-use-openssl-rand

# Credential encryption key for integration credentials (Slack/Discord tokens).
# Required if you enable Slack or Discord integrations. Separate from LUCENT_SECRET_KEY.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# LUCENT_CREDENTIAL_KEY=

# OpenBao / Vault Configuration
BAO_DEV_ROOT_TOKEN_ID=change-me-insecure-dev-root-token
VAULT_TOKEN=change-me-insecure-dev-root-token

# Daemon Configuration
# LUCENT_MAX_SESSIONS=3
# LUCENT_DAEMON_INTERVAL=15
# LUCENT_DAEMON_MODEL=claude-opus-4.6
# LUCENT_DAEMON_RESEARCH_MODEL=claude-opus-4.6
# LUCENT_MCP_URL=http://localhost:8766/mcp
# LUCENT_MCP_API_KEY=mcp_your_api_key_here
# LUCENT_STALE_HEARTBEAT_MINUTES=30
# Used only when DAEMON_DATABASE_URL and DATABASE_URL are unset (personal mode).
# Override if your local postgres password differs from docker-compose defaults.
# LUCENT_DEV_DATABASE_URL=postgresql://lucent:your-local-password@localhost:5433/lucent

# Daemon Review & Approval
# Auto-approve daemon-initiated requests (set false to require human approval)
# LUCENT_AUTO_APPROVE=false
# Skip the daemon's automatic post-completion quality review
# LUCENT_SKIP_POST_REVIEW=false
# Require human approval of completed requests (moves them to "review" status)
# LUCENT_REQUIRE_APPROVAL=false

# LLM Engine: "copilot" (default, uses GitHub Copilot SDK) or "langchain"
# LUCENT_LLM_ENGINE=copilot
# Default model for chat sessions
# LUCENT_CHAT_MODEL=claude-opus-4.6

# LLM Provider API Keys (only needed when LUCENT_LLM_ENGINE=langchain)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# GitHub Token — REQUIRED for daemon and chat features when using Copilot SDK engine.
# Must be a GitHub personal access token (classic) with "copilot" scope,
# or a fine-grained token with GitHub Copilot permissions.
# The daemon and chat features use this to call LLM models via the GitHub Copilot SDK.
# Not needed if LUCENT_LLM_ENGINE=langchain (uses provider API keys instead).
# GITHUB_TOKEN=your_github_token_here
