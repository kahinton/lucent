# PostgreSQL Configuration
POSTGRES_USER=lucent
POSTGRES_PASSWORD=lucent_dev_password
POSTGRES_DB=lucent

# Database URL (for running outside Docker Compose)
DATABASE_URL=postgresql://lucent:lucent_dev_password@localhost:5433/lucent

# Server Configuration
LUCENT_HOST=0.0.0.0
LUCENT_PORT=8766

# Deployment Mode (personal or team)
# Team mode requires a license key
LUCENT_MODE=personal
# LUCENT_LICENSE_KEY=your-license-key

# Authentication Provider (basic or api_key)
LUCENT_AUTH_PROVIDER=basic

# Session TTL in hours (default: 72)
LUCENT_SESSION_TTL_HOURS=24

# Log format: human or json (default: human)
LUCENT_LOG_FORMAT=human
# LUCENT_LOG_LEVEL=INFO

# Database port (for docker-compose, default: 5433)
# LUCENT_DB_PORT=5433

# Rate limiting (requests per minute per API key, default: 100)
# LUCENT_RATE_LIMIT_PER_MINUTE=100

# Cookie security (defaults to true; set to false for local HTTP development)
# LUCENT_SECURE_COOKIES=true

# CORS origins (comma-separated, default: * for development)
# LUCENT_CORS_ORIGINS=http://localhost:8766

# Secret Storage Provider (builtin, vault, aws, or azure)
LUCENT_SECRET_PROVIDER=builtin
LUCENT_SECRET_KEY=lucent-dev-secret-key-change-in-production

# Daemon Configuration
# LUCENT_MAX_SESSIONS=3
# LUCENT_DAEMON_INTERVAL=15
# LUCENT_DAEMON_MODEL=claude-opus-4.6
# LUCENT_DAEMON_RESEARCH_MODEL=claude-opus-4.6
# LUCENT_MCP_URL=http://localhost:8766/mcp
# LUCENT_MCP_API_KEY=mcp_your_api_key_here
