# PostgreSQL Configuration
POSTGRES_USER=hindsight
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hindsight

# Database URL (for the application)
DATABASE_URL=postgresql://hindsight:changeme@localhost:5432/hindsight

# Server Configuration
HINDSIGHT_HOST=0.0.0.0
HINDSIGHT_PORT=8765

# Development Mode
# Set to true to bypass authentication and use a local dev user
HINDSIGHT_DEV_MODE=true
HINDSIGHT_DEV_USER_ID=dev-user
HINDSIGHT_DEV_USER_NAME=Development User
HINDSIGHT_DEV_ORG_NAME=Development Organization
